<div class="dropdown">
  <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
    <%= translate_scoped("actions.label") %>
  </a>
  <ul class="dropdown-menu dropdown-menu-end">
    <% if policy(@resource).show? && action_name != "show" %>
      <li>
        <%= link_to translate_scoped("actions.show"), resource_url_array, class: "dropdown-item" %>
      </li>
    <% end %>
    <% if policy(@resource).edit? && action_name != "edit" %>
      <li>
        <%= link_to translate_scoped("actions.edit"), resource_url_array(action: :edit), class: "dropdown-item" %>
      </li>
    <% end %>
    <% if policy(@resource).destroy? %>
      <li>
        <%= link_to translate_scoped("actions.destroy"), resource_url_array, method: :delete,
          class: "dropdown-item",
          data: { confirm: translate_scoped("actions.confirm_message") } %>
      </li>
    <% end %>
  </ul>
</div>

<% if @resource_service.has_many_map.present? %>
  <div class="dropdown">
    <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
      <%= translate_scoped("associations.label") %>
    </a>
    <ul class="dropdown-menu dropdown-menu-end">
      <% @resource_service.has_many_map.each do |name, options| %>
        <% if policy(options[:class_name].constantize).index? %>
          <li>
            <%= link_to(options[:class_name].constantize.model_name.human(count: 2),
              polymorphic_path([*@resource_parents, @resource, options[:class_name].constantize]),
              class: "dropdown-item") %>
          </li>
        <% end %>
      <% end %>
    </ul>
  </div>
<% end %>
